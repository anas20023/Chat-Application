# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/chatdb

# Firebase Admin (optional, for push notifications or other Firebase services)
# Provide the service account JSON as a string in the environment variable
# FIREBASE_SERVICE_ACCOUNT='{"type": "...", "project_id": "...", ...}'

# Server Port
PORT=5000

# Client URL for CORS (adjust as needed)
CLIENT_URL=http://localhost:3000